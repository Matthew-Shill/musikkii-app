# LOCAL / DEV ONLY — copy to `.env.seeding.local` (gitignored) for `npm run seed:dev-users`.
# Never commit `.env.seeding.local` or use service-role keys in production frontends.

# API URL: optional here if you already set VITE_SUPABASE_URL or SUPABASE_URL in `.env`
# SUPABASE_URL=http://127.0.0.1:54321

# Required: the REAL service_role JWT from `supabase status` (NOT a placeholder, NOT anon key).
# Must be one line, three dot-separated segments (starts with eyJ...).
# SUPABASE_SERVICE_ROLE_KEY=
