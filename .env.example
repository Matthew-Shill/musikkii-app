# Copy to `.env` and fill with values from the Supabase dashboard (Settings → API).
# For local CLI: `supabase status` prints API URL and anon key after `supabase start`.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional local dev: same value as `DEV_SEED_PASSWORD` when seeding (`npm run seed:dev-users`).
# Required for the dev-only account switcher UI. Never commit a real secret; use `.env.local`.
# VITE_DEV_SEED_PASSWORD=
